# Optional local overrides for emulator/dev
# (Secrets like TWILIO_AUTH_TOKEN should NOT be committed; use `firebase functions:secrets:set` for deploy)

# Twilio credentials (required for local `call:test` and for emulators)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Voice/modulation
# Native Twilio voices: "woman" (female), "man" (male)
# Optional enhanced: "Polly.Joanna" etc (if your Twilio account supports it)
ALERT_VOICE=woman

# Modulation: slow | normal | fast
ALERT_SPEECH_RATE=normal

# Where to call when AQI crosses > 50
ALERT_TO_NUMBER=+919372797798
